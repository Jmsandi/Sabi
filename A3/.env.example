# A3 — copy to .env and fill in, then run `npm start`.
# .env is gitignored; .env.example is committed as documentation.

# Provider to use: openai | gemini | mock  (mock needs no key and makes no network calls)
EXTRACTION_PROVIDER=gemini

# Required when EXTRACTION_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here

# Required when EXTRACTION_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Optional overrides (defaults shown)
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_TIMEOUT_MS=30000
# OPENAI_MAX_ATTEMPTS=3
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_TIMEOUT_MS=30000
# GEMINI_MAX_ATTEMPTS=3
# INPUT_DIRECTORY=input/papers
# OUTPUT_CSV_PATH=output/extracted-studies.csv
